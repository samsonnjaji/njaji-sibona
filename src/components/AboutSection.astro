---
import { intro } from "../data/site";
---

<section id="experience" class="about band" aria-labelledby="about-heading">
	<div class="inner">
		<div class="head">
			<span class="kicker">About</span>
			<h2 id="about-heading" class="h2">The longer version</h2>
		</div>
		<div class="card">
			<div class="glow" aria-hidden="true" />
			<p class="intro">{intro}</p>
		</div>
	</div>
</section>

<style>
	.about {
		scroll-margin-top: 5rem;
	}

	.inner {
		max-width: var(--max);
		margin: 0 auto;
		padding: 3rem 1.35rem;
	}

	.head {
		margin-bottom: 1.25rem;
	}

	.kicker {
		display: block;
		margin-bottom: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.h2 {
		margin: 0;
		font-size: clamp(1.35rem, 2.5vw, 1.65rem);
		font-weight: 650;
		letter-spacing: -0.03em;
	}

	.card {
		position: relative;
		border-radius: var(--radius);
		padding: 1.25rem 1.35rem 1.35rem;
		background: var(--bg-elevated);
		border: 1px solid var(--border-strong);
		overflow: hidden;
	}

	.glow {
		position: absolute;
		top: -40%;
		right: -20%;
		width: 55%;
		height: 180%;
		background: radial-gradient(circle, rgba(34, 211, 238, 0.12), transparent 65%);
		pointer-events: none;
	}

	.intro {
		position: relative;
		margin: 0;
		font-size: 1.02rem;
		line-height: 1.75;
		color: var(--text-muted);
		max-width: 68ch;
	}
</style>

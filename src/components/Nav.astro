---
import { site } from "../data/site";

const links = [
	{ href: "#experience", label: "About" },
	{ href: "#skills", label: "Skills" },
	{ href: "#projects", label: "Work" },
	{ href: "#github", label: "GitHub" },
	{ href: "#credentials", label: "Credentials" },
	{ href: "#contact", label: "Contact" },
];
---

<header class="nav-wrap">
	<nav class="nav" aria-label="Primary">
		<a class="brand" href="#top">
			<img
				class="brand-avatar"
				src={site.avatar}
				alt=""
				width="32"
				height="32"
				loading="eager"
				decoding="async"
			/>
			<span class="brand-mono" aria-hidden="true">~/</span>
			<span class="brand-name">{site.author.split(" ")[0].toLowerCase()}</span>
		</a>
		<ul class="nav-list">
			{
				links.map(({ href, label }) => (
					<li>
						<a href={href}>{label}</a>
					</li>
				))
			}
		</ul>
	</nav>
</header>

<style>
	.nav-wrap {
		position: sticky;
		top: 0;
		z-index: 50;
		backdrop-filter: blur(16px) saturate(1.2);
		background: rgba(9, 9, 11, 0.82);
		border-bottom: 1px solid var(--border-strong);
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: var(--max);
		margin: 0 auto;
		padding: 0.9rem 1.35rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 600;
		font-size: 0.95rem;
		letter-spacing: -0.02em;
		color: var(--text);
		font-family: var(--font-mono);
	}

	.brand:hover {
		color: var(--accent);
	}

	.brand-avatar {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		object-fit: cover;
		border: 1px solid var(--border-strong);
		flex-shrink: 0;
	}

	.brand-mono {
		color: var(--text-dim);
		font-weight: 500;
	}

	.brand-name {
		color: var(--accent);
	}

	.nav-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 1.1rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.nav-list a {
		font-size: 0.8rem;
		font-weight: 500;
		font-family: var(--font-mono);
		letter-spacing: 0.02em;
		color: var(--text-muted);
		padding: 0.35rem 0;
		border-bottom: 2px solid transparent;
	}

	.nav-list a:hover {
		color: var(--text);
		border-bottom-color: var(--accent);
	}

	@media (max-width: 640px) {
		.nav {
			flex-direction: column;
			align-items: flex-start;
		}

		.nav-list {
			gap: 0.35rem 0.75rem;
		}

		.nav-list a {
			font-size: 0.76rem;
		}
	}
</style>

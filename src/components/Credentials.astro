---
import { credentials, site } from "../data/site";
---

<section id="credentials" class="section band-alt" aria-labelledby="creds-heading">
	<span class="section-kicker">Credentials</span>
	<h2 id="creds-heading" class="section-title">Proof of practice</h2>
	<p class="section-lead">
		Badges and certifications — including <strong>co-lead &amp; technical lead</strong> on the
		<a href={site.social.awsCloudClubCredly}>AWS Cloud Club core team</a> (Credly). I did not found the
		chapter; I help run programs and mentor builders.
	</p>

	<ul class="list">
		{
			credentials.map((c) =>
				"featured" in c && c.featured ? (
					<li class="item featured">
						<a
							class="featured-link"
							href={c.url}
							target="_blank"
							rel="noopener noreferrer"
						>
							<div class="seal" aria-hidden="true">
								<span class="seal-inner">AWS</span>
							</div>
							<div class="featured-body">
								<p class="featured-issuer">{c.issuer}</p>
								<p class="featured-name">{c.name}</p>
								<p class="featured-sub">{c.subtitle}</p>
								<p class="featured-meta">
									{c.year} · <span class="verify">Verify on Credly →</span>
								</p>
							</div>
						</a>
					</li>
				) : (
					<li class="item">
						<strong>{c.name}</strong>
						{c.year ? <span class="year"> · {c.year}</span> : null}
						{"url" in c && c.url ? (
							<div class="row">
								<a href={c.url} target="_blank" rel="noopener noreferrer">
									{"linkLabel" in c && (c as { linkLabel?: string }).linkLabel
										? (c as { linkLabel: string }).linkLabel
										: "View credential"}
								</a>
							</div>
						) : null}
						{"note" in c && c.note ? <div class="note muted">{c.note}</div> : null}
					</li>
				),
			)
		}
	</ul>
	<p class="more">
		<a href={site.social.credlyProfile} target="_blank" rel="noopener noreferrer">
			Full Credly profile →
		</a>
	</p>
</section>

<style>
	.section {
		max-width: var(--max);
		margin: 0 auto;
		padding: 0 1.35rem 2.75rem;
		scroll-margin-top: 5rem;
	}

	.section-kicker {
		display: block;
		margin-bottom: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.section-title {
		margin: 0 0 0.5rem;
		font-size: clamp(1.35rem, 2.5vw, 1.65rem);
		font-weight: 650;
		letter-spacing: -0.03em;
	}

	.section-lead strong {
		color: var(--text);
		font-weight: 600;
	}

	.section-lead {
		margin: 0 0 1.35rem;
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.65;
		max-width: 52ch;
	}

	.section-lead a {
		font-weight: 600;
	}

	.list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.item {
		padding: 1rem 1.15rem;
		background: var(--bg-elevated);
		border: 1px solid var(--border-strong);
		border-radius: var(--radius-sm);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.item.featured {
		padding: 0;
		border: none;
		background: transparent;
	}

	.featured-link {
		display: flex;
		align-items: stretch;
		gap: 0;
		padding: 0;
		border-radius: var(--radius);
		overflow: hidden;
		border: 1px solid var(--border-strong);
		background: linear-gradient(135deg, #1c1410 0%, var(--bg-elevated) 40%, #0a1620 100%);
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.featured-link:hover {
		border-color: rgba(251, 191, 36, 0.35);
		box-shadow: 0 0 0 1px rgba(34, 211, 238, 0.12), 0 20px 40px rgba(0, 0, 0, 0.4);
	}

	.seal {
		flex-shrink: 0;
		width: 112px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: radial-gradient(ellipse at 30% 20%, #fbbf24 0%, #b45309 55%, #1e3a5f 100%);
		border-right: 1px solid rgba(255, 255, 255, 0.08);
	}

	.seal-inner {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: #0c0a09;
		text-shadow: 0 1px 0 rgba(255, 255, 255, 0.25);
	}

	.featured-body {
		padding: 1.15rem 1.25rem;
		flex: 1;
	}

	.featured-issuer {
		margin: 0 0 0.25rem;
		font-family: var(--font-mono);
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-dim);
	}

	.featured-name {
		margin: 0 0 0.15rem;
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--text);
	}

	.featured-sub {
		margin: 0 0 0.85rem;
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--accent);
	}

	.featured-meta {
		margin: 0;
		font-size: 0.82rem;
		color: var(--text-muted);
	}

	.verify {
		color: var(--accent-2);
		font-weight: 600;
	}

	.year {
		color: var(--text-muted);
		font-weight: 500;
	}

	.row {
		margin-top: 0.5rem;
	}

	.row a {
		font-weight: 600;
		font-size: 0.9rem;
	}

	.note {
		margin-top: 0.35rem;
		font-size: 0.82rem;
	}

	.muted {
		color: var(--text-muted);
	}

	.more {
		margin: 1.15rem 0 0;
		font-size: 0.9rem;
		font-family: var(--font-mono);
	}
</style>

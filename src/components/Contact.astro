---
import { site } from "../data/site";
---

<section id="contact" class="section band" aria-labelledby="contact-heading">
	<span class="section-kicker">Contact</span>
	<h2 id="contact-heading" class="section-title">Let’s work together</h2>
	<p class="section-lead">
		Product builds, cloud mentorship, or a technical conversation — pick a channel below.
	</p>
	<div class="panel">
		<div class="block">
			<p class="label">Primary email</p>
			<a class="email" href={`mailto:${site.email}`}>{site.email}</a>
		</div>
		<div class="block">
			<p class="label">Secondary email</p>
			<a class="email secondary" href={`mailto:${site.emailSecondary}`}>{site.emailSecondary}</a>
		</div>
		<div class="block">
			<p class="label">Phone</p>
			<a class="email" href={`tel:${site.phone.replace(/\s/g, "")}`}>{site.phone}</a>
		</div>
		<div class="links">
			<a href={site.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
			<span class="dot" aria-hidden="true">·</span>
			<a href={site.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
			<span class="dot" aria-hidden="true">·</span>
			<a href={site.social.credlyProfile} target="_blank" rel="noopener noreferrer">Credly</a>
		</div>
	</div>
</section>

<style>
	.section {
		max-width: var(--max);
		margin: 0 auto;
		padding: 2.5rem 1.35rem 3.25rem;
		scroll-margin-top: 5rem;
	}

	.section-kicker {
		display: block;
		margin-bottom: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.section-title {
		margin: 0 0 0.5rem;
		font-size: clamp(1.35rem, 2.5vw, 1.65rem);
		font-weight: 650;
		letter-spacing: -0.03em;
	}

	.section-lead {
		margin: 0 0 1.25rem;
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.65;
		max-width: 50ch;
	}

	.panel {
		padding: 1.5rem 1.6rem;
		background: linear-gradient(145deg, var(--bg-elevated) 0%, var(--surface) 100%);
		border: 1px solid var(--border-strong);
		border-radius: var(--radius);
		max-width: 520px;
	}

	.block {
		margin-bottom: 1rem;
	}

	.block:last-of-type {
		margin-bottom: 0;
	}

	.label {
		margin: 0 0 0.25rem;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-dim);
	}

	.email {
		display: inline-block;
		font-size: 1.02rem;
		font-weight: 600;
	}

	.email.secondary {
		font-size: 0.95rem;
		font-weight: 500;
	}

	.links {
		margin-top: 1.15rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
		font-size: 0.92rem;
		font-family: var(--font-mono);
		color: var(--text-muted);
	}

	.links a {
		font-weight: 500;
	}

	.dot {
		margin: 0 0.35rem;
		opacity: 0.5;
	}
</style>

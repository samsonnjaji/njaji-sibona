---
/**
 * GitHub public API — client-rendered. Dynamic nodes use gh-* + `is:global` styles under #github.
 */
import { githubExcludedRepoSlugs, githubRepoBoostFirst, site } from "../data/site";

const user = site.githubUsername;
const profileUrl = `https://github.com/${user}`;
const excluded = [...githubExcludedRepoSlugs];
const boost = [...githubRepoBoostFirst].map((s) => s.toLowerCase());
---

<section id="github" class="gh-section band-alt" aria-labelledby="github-heading">
	<div class="gh-contain">
		<div class="gh-section-head">
			<span class="gh-eyebrow">Open source</span>
			<h2 id="github-heading" class="gh-title">GitHub</h2>
			<p class="gh-lead">Public repositories and code samples.</p>
		</div>

		<div class="gh-shell">
			<div id="gh-stats-root" class="gh-stats-root" aria-live="polite">
				<p class="gh-loading">Loading…</p>
			</div>

			<a class="gh-cta" href={profileUrl} target="_blank" rel="noopener noreferrer">
				<span class="gh-cta-label">View profile on GitHub</span>
				<span class="gh-cta-arrow" aria-hidden="true">→</span>
				<span class="gh-cta-hint">
					Full contribution calendar, pins, and private repos appear only on GitHub.
				</span>
			</a>

			<div class="gh-repos-wrap">
				<div class="gh-repos-head">
					<h3 class="gh-repos-title">Public repositories</h3>
					<p id="gh-live-status" class="gh-repos-meta" aria-live="polite"></p>
				</div>
				<ul id="gh-live-repos" class="gh-repo-list" data-empty="true"></ul>
			</div>
		</div>

		<p class="gh-footnote">
			Only <strong>public</strong> repositories are listed here. NDA and private work is covered in the
			projects section above.
		</p>
	</div>
</section>

<script define:vars={{ user, excluded, boost }}>
	const statusEl = document.getElementById("gh-live-status");
	const listEl = document.getElementById("gh-live-repos");
	const statsRoot = document.getElementById("gh-stats-root");
	const excludedSet = new Set(excluded.map((s) => s.toLowerCase()));
	const boostSet = new Set(boost);

	function sortRepos(repos) {
		const filtered = repos.filter((r) => !excludedSet.has(r.name.toLowerCase()));
		const boosted = [];
		const rest = [];
		for (const r of filtered) {
			if (boostSet.has(r.name.toLowerCase())) boosted.push(r);
			else rest.push(r);
		}
		boosted.sort((a, b) => a.name.localeCompare(b.name));
		rest.sort((a, b) => new Date(b.updated_at) - new Date(a.updated_at));
		return [...boosted, ...rest].slice(0, 14);
	}

	function el(tag, cls, text) {
		const n = document.createElement(tag);
		if (cls) n.className = cls;
		if (text != null) n.textContent = text;
		return n;
	}

	function renderStats(u) {
		if (!statsRoot) return;
		statsRoot.textContent = "";
		const since = u.created_at ? String(new Date(u.created_at).getFullYear()) : "—";

		const profile = el("div", "gh-profile");
		if (u.avatar_url) {
			const img = document.createElement("img");
			img.className = "gh-avatar";
			img.src = u.avatar_url;
			img.width = 64;
			img.height = 64;
			img.alt = "";
			img.loading = "lazy";
			img.decoding = "async";
			profile.appendChild(img);
		}
		const who = el("div", "gh-who");
		who.appendChild(el("p", "gh-display", u.name || u.login));
		who.appendChild(el("p", "gh-handle", `@${u.login}`));
		if (u.bio) who.appendChild(el("p", "gh-bio", u.bio));
		profile.appendChild(who);
		statsRoot.appendChild(profile);

		const grid = el("div", "gh-metric-grid");
		const metrics = [
			{ val: String(u.public_repos ?? "—"), lab: "Public repos" },
			{ val: String(u.followers ?? 0), lab: "Followers" },
			{ val: String(u.following ?? 0), lab: "Following" },
			{ val: since, lab: "Member since" },
		];
		for (const m of metrics) {
			const card = el("div", "gh-metric");
			card.appendChild(el("span", "gh-metric-value", m.val));
			card.appendChild(el("span", "gh-metric-label", m.lab));
			grid.appendChild(card);
		}
		statsRoot.appendChild(grid);
	}

	async function load() {
		if (!listEl || !statusEl) return;
		statusEl.textContent = "Loading…";

		try {
			const [userRes, repoRes] = await Promise.all([
				fetch(`https://api.github.com/users/${user}`),
				fetch(`https://api.github.com/users/${user}/repos?per_page=100&sort=updated&type=all`),
			]);

			if (!userRes.ok) throw new Error("user " + userRes.status);
			if (!repoRes.ok) throw new Error("repos " + repoRes.status);

			const u = await userRes.json();
			/** @type {Array<{ name: string; html_url: string; description: string | null; stargazers_count: number; language: string | null; fork: boolean; private: boolean; updated_at: string }>} */
			const allRepos = await repoRes.json();

			renderStats(u);

			const sorted = sortRepos(allRepos);
			listEl.innerHTML = "";
			listEl.dataset.empty = sorted.length === 0 ? "true" : "false";

			if (sorted.length === 0) {
				statusEl.textContent = "No public repositories in this view.";
				return;
			}

			statusEl.textContent = `${sorted.length} repositories · priority projects first`;

			for (const r of sorted) {
				const li = document.createElement("li");
				li.className = "gh-repo";

				const row = el("div", "gh-repo-row");
				const name = document.createElement("a");
				name.href = r.html_url;
				name.target = "_blank";
				name.rel = "noopener noreferrer";
				name.className = "gh-repo-name";
				name.textContent = r.name;

				const meta = el("span", "gh-repo-pills");
				const pills = [];
				if (r.private) pills.push("Private");
				if (r.fork) pills.push("Fork");
				if (r.language) pills.push(r.language);
				meta.textContent = pills.join(" · ");

				row.appendChild(name);
				row.appendChild(meta);
				li.appendChild(row);

				if (r.description) {
					li.appendChild(el("p", "gh-repo-desc", r.description));
				}

				listEl.appendChild(li);
			}
		} catch {
			if (statsRoot) {
				statsRoot.textContent = "";
				const wrap = el("div", "gh-error");
				wrap.appendChild(
					document.createTextNode("Could not load GitHub data right now. "),
				);
				const a = document.createElement("a");
				a.href = `https://github.com/${user}`;
				a.target = "_blank";
				a.rel = "noopener noreferrer";
				a.className = "gh-error-link";
				a.textContent = "Open GitHub profile";
				wrap.appendChild(a);
				statsRoot.appendChild(wrap);
			}
			statusEl.textContent = "";
			listEl.dataset.empty = "true";
		}
	}

	load();
</script>

<style>
	/* Section layout (static — scoped OK) */
	.gh-section {
		scroll-margin-top: 5rem;
	}

	.gh-contain {
		max-width: var(--max);
		margin: 0 auto;
		padding: 2.75rem 1.35rem 3rem;
	}

	.gh-section-head {
		margin-bottom: 1.35rem;
	}

	.gh-eyebrow {
		display: block;
		margin-bottom: 0.45rem;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-dim);
	}

	.gh-title {
		margin: 0 0 0.4rem;
		font-size: clamp(1.4rem, 2.6vw, 1.75rem);
		font-weight: 650;
		letter-spacing: -0.03em;
	}

	.gh-lead {
		margin: 0;
		max-width: 48ch;
		font-size: 0.98rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	.gh-shell {
		border-radius: var(--radius);
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: linear-gradient(180deg, rgba(22, 27, 34, 0.85) 0%, rgba(13, 17, 23, 0.65) 100%);
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.04) inset;
		overflow: hidden;
	}



	.gh-cta {
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-rows: auto auto;
		gap: 0.15rem 0.75rem;
		align-items: center;
		padding: 1.1rem 1.4rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		color: inherit;
		text-decoration: none;
		transition: background 0.15s ease;
	}

	.gh-cta:hover {
		background: rgba(255, 255, 255, 0.03);
	}

	.gh-cta-label {
		font-weight: 650;
		font-size: 0.95rem;
		color: var(--accent);
	}

	.gh-cta-arrow {
		grid-row: 1 / span 2;
		font-size: 1.15rem;
		color: var(--text-dim);
	}

	.gh-cta-hint {
		grid-column: 1;
		font-size: 0.8rem;
		line-height: 1.45;
		color: var(--text-dim);
	}

	.gh-repos-wrap {
		background: rgba(0, 0, 0, 0.2);
	}

	.gh-repos-head {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.5rem 1rem;
		padding: 0.95rem 1.4rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.gh-repos-title {
		margin: 0;
		font-size: 0.75rem;
		font-weight: 700;
		font-family: var(--font-mono);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.gh-repos-meta {
		margin: 0;
		font-size: 0.75rem;
		color: var(--text-dim);
		font-family: var(--font-mono);
	}

	.gh-repo-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}


	.gh-footnote {
		margin: 1.15rem 0 0;
		font-size: 0.82rem;
		line-height: 1.55;
		color: var(--text-dim);
		max-width: 52ch;
	}

	.gh-footnote strong {
		color: var(--text-muted);
		font-weight: 600;
	}
</style>

<!-- JS-injected markup has no Astro scope attrs; global styles under #github avoid glued metrics / plain lists -->
<style is:global>
	#github .gh-stats-root {
		padding: 1.35rem 1.4rem 1.25rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	#github .gh-loading {
		margin: 0;
		font-size: 0.9rem;
		color: var(--text-dim);
	}

	#github .gh-profile {
		display: flex;
		align-items: flex-start;
		gap: 1.1rem;
		margin-bottom: 1.35rem;
	}

	#github .gh-avatar {
		border-radius: 50%;
		border: 2px solid rgba(255, 255, 255, 0.12);
		flex-shrink: 0;
	}

	#github .gh-who {
		min-width: 0;
		flex: 1;
	}

	#github .gh-display {
		margin: 0 0 0.2rem;
		font-size: 1.12rem;
		font-weight: 650;
		letter-spacing: -0.02em;
	}

	#github .gh-handle {
		margin: 0 0 0.35rem;
		font-family: var(--font-mono);
		font-size: 0.88rem;
		color: var(--accent);
	}

	#github .gh-bio {
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.5;
		color: var(--text-muted);
	}

	#github .gh-metric-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.65rem;
	}

	@media (max-width: 900px) {
		#github .gh-metric-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 400px) {
		#github .gh-metric-grid {
			grid-template-columns: 1fr;
		}
	}

	#github .gh-metric {
		padding: 0.85rem 0.9rem;
		border-radius: 10px;
		background: rgba(0, 0, 0, 0.35);
		border: 1px solid rgba(255, 255, 255, 0.06);
		text-align: center;
	}

	#github .gh-metric-value {
		display: block;
		font-family: var(--font-mono);
		font-size: 1.28rem;
		font-weight: 700;
		color: var(--text);
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	#github .gh-metric-label {
		display: block;
		margin-top: 0.4rem;
		font-size: 0.68rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-dim);
		line-height: 1.3;
	}

	#github .gh-error {
		margin: 0;
		font-size: 0.92rem;
		color: var(--text-muted);
		line-height: 1.55;
	}

	#github .gh-error-link {
		font-weight: 600;
	}

	#github .gh-repo {
		padding: 1rem 1.4rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}

	#github .gh-repo:last-child {
		border-bottom: none;
	}

	#github .gh-repo-row {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.4rem 1rem;
	}

	#github .gh-repo-name {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
	}

	#github .gh-repo-name:hover {
		color: var(--accent-hover);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	#github .gh-repo-pills {
		font-size: 0.72rem;
		color: var(--text-dim);
		font-family: var(--font-mono);
	}

	#github .gh-repo-desc {
		margin: 0.55rem 0 0;
		font-size: 0.87rem;
		line-height: 1.55;
		color: var(--text-muted);
		max-width: 72ch;
	}
</style>
